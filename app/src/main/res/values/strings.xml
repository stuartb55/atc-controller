    <!-- Authored and engine-generated presentation text. Simulation data stays Android-free. -->
    <string name="mission_01_title">First Contact</string>
    <string name="mission_01_briefing">Select each arrival, set up its approach, then clear it to land while keeping traffic separated.</string>
    <string name="mission_02_title">Level Headed</string>
    <string name="mission_02_briefing">Use altitude assignments to safely cross converging arrivals.</string>
    <string name="mission_03_title">Slow and Steady</string>
    <string name="mission_03_briefing">Build spacing with speed control before turning aircraft onto final.</string>
    <string name="mission_04_title">Cleared to Land</string>
    <string name="mission_04_briefing">Issue landing clearances only when the approach is stable and the runway is clear. Send an unsafe approach around.</string>
    <string name="mission_05_title">Opening the Flow</string>
    <string name="mission_05_briefing">Clear departures for takeoff, then guide them to their assigned exit while arrivals continue.</string>
    <string name="mission_06_title">Mind the Runway</string>
    <string name="mission_06_briefing">Sequence arrivals and departures without allowing their runway occupancy to overlap.</string>
    <string name="mission_07_title">Mixed Picture</string>
    <string name="mission_07_briefing">Manage a denser mix of performance classes, arrivals and departures.</string>
    <string name="mission_08_title">Parallel Pressure</string>
    <string name="mission_08_briefing">Use both parallel runways to keep a busy final session moving safely.</string>
    <string name="mission_09_title">Heavy Spacing</string>
    <string name="mission_09_briefing">Sequence heavy leaders and light followers using the displayed simplified wake interval.</string>
    <string name="mission_10_title">Weather Window</string>
    <string name="mission_10_briefing">Allow for deterministic wind drift and stabilize arrivals earlier in reduced visibility.</string>
    <string name="mission_11_title">Hold and Handoff</string>
    <string name="mission_11_briefing">Accept inbound handoffs, use fix holds to absorb delay, then clear and hand departures to the exit sector.</string>
    <string name="mission_12_title">Recovery Shift</string>
    <string name="mission_12_briefing">Respond to a deterministic schedule of priority traffic, a rejected takeoff, a closure, and a prediction outage.</string>
