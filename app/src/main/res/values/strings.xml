    <string name="tutorial_identify_title">Read the traffic</string>
    <string name="tutorial_identify_body">Every target shows a callsign, altitude and speed. Amber rings flag a predicted conflict.</string>
    <string name="tutorial_select_kicker">02 • Select</string>
    <string name="tutorial_select_title">Take control</string>
    <string name="tutorial_select_body">Tap EXS72M on the radar to open its aircraft strip and command controls.</string>
    <string name="tutorial_vector_kicker">03 • Vector</string>
    <string name="tutorial_vector_title">Choose a route</string>
    <string name="tutorial_vector_body">Drag across the radar, or use the Direct route shortcut in the command panel.</string>
